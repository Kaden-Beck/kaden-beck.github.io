{
    "servers": {
        "mui-mcp": {
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "@mui/mcp@latest"]
        },
        "next-devtools": {
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "next-devtools-mcp@latest"]
        },
        "ESLint": {
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "@eslint/mcp@latest"]
        },
        "prettier": {
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "@prettier/mcp"]
        }
    }
}
